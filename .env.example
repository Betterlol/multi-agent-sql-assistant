# Optional default LLM provider for server-side fallback
SQL_ASSISTANT_LLM_PROVIDER=
OPENAI_API_KEY=
SQL_ASSISTANT_OPENAI_MODEL=gpt-4o-mini
SQL_ASSISTANT_OPENAI_BASE_URL=https://api.openai.com/v1

# Upload lifecycle
SQL_ASSISTANT_UPLOAD_ROOT=/app/runtime_uploads
SQL_ASSISTANT_UPLOAD_TTL_SECONDS=86400
SQL_ASSISTANT_UPLOAD_MAX_BYTES=31457280

# Logging
SQL_ASSISTANT_LOG_LEVEL=INFO
